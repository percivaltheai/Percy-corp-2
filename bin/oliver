#!/usr/bin/env python3
"""
Oliver - Creative Director
Full ComfyUI automation for generation, character consistency, and video
"""
import requests
import json
import time
import uuid
import os
from pathlib import Path
from typing import Optional, Dict, Any

COMFY_URL = "http://localhost:8000"
OUTPUT_DIR = Path.home() / "Documents/ComfyUI/output"

class Oliver:
    """Creative Director - ComfyUI automation"""
    
    def check(self) -> bool:
        """Check if ComfyUI is running"""
        try:
            r = requests.get(f"{COMFY_URL}/system_stats", timeout=5)
            return r.status_code == 200
        except:
            return False
    
    def generate(self, prompt: str, negative: str = "", 
                width: int = 1024, height: int = 1024,
                steps: int = 25, seed: int = None,
                model: str = "sd_xl_base_1.0.safetensors") -> Dict[str, Any]:
        """Generate an image"""
        
        if not self.check():
            return {"status": "error", "message": "ComfyUI not running. Start: open /Applications/ComfyUI.app"}
        
        # Use seed or random
        if seed is None:
            seed = int(time.time()) % 1000000000
        
        # Build prompt with proper node connections
        prompt_id = str(uuid.uuid4())
        
        wf = {
            "1": {
                "class_type": "CheckpointLoaderSimple",
                "inputs": {"ckpt_name": model}
            },
            "2": {
                "class_type": "CLIPTextEncode",
                "inputs": {"text": prompt, "clip": ["1", 1]}
            },
            "3": {
                "class_type": "CLIPTextEncode", 
                "inputs": {"text": negative or "blurry, low quality, watermark, text", "clip": ["1", 1]}
            },
            "4": {
                "class_type": "EmptyLatentImage",
                "inputs": {"width": width, "height": height, "batch_size": 1}
            },
            "5": {
                "class_type": "KSampler",
                "inputs": {
                    "seed": seed,
                    "steps": steps,
                    "cfg": 8,
                    "sampler_name": "euler",
                    "scheduler": "normal",
                    "denoise": 1,
                    "model": ["1", 0],
                    "positive": ["2", 0],
                    "negative": ["3", 0],
                    "latent_image": ["4", 0]
                }
            },
            "6": {
                "class_type": "VAEDecode",
                "inputs": {"samples": ["5", 0], "vae": ["1", 2]}
            },
            "7": {
                "class_type": "SaveImage",
                "inputs": {"images": ["6", 0], "filename_prefix": f"oliver_{seed}"}
            }
        }
        
        try:
            resp = requests.post(
                f"{COMFY_URL}/prompt",
                json={"prompt": wf, "prompt_id": prompt_id},
                timeout=30
            )
            
            if resp.status_code == 200:
                result = resp.json()
                return {
                    "status": "queued",
                    "prompt_id": result.get('prompt_id', prompt_id),
                    "seed": seed,
                    "message": f"Generation queued (seed: {seed})"
                }
            else:
                return {"status": "error", "message": f"API error: {resp.status_code}"}
                
        except Exception as e:
            return {"status": "error", "message": str(e)}
    
    def get_history(self, limit: int = 10) -> Dict:
        """Get generation history"""
        try:
            r = requests.get(f"{COMFY_URL}/history", timeout=5)
            history = r.json()
            
            items = list(history.get('history', {}).items())
            items.reverse()
            
            results = []
            for prompt_id, data in items[:limit]:
                status = data.get('status', {})
                results.append({
                    'prompt_id': prompt_id,
                    'completed': status.get('completed', False),
                    'time': data.get('started', 0)
                })
            
            return {"history": results}
        except Exception as e:
            return {"error": str(e)}
    
    def list_models(self) -> Dict:
        """List available checkpoints"""
        try:
            r = requests.get(f"{COMFY_URL}/object_info/CheckpointLoaderSimple", timeout=5)
            info = r.json()
            ckpts = info.get('CheckpointLoaderSimple', {}).get('input', {}).get('required', {}).get('ckpt_name', [{}])
            if isinstance(ckpts, list) and len(ckpts) > 0:
                choices = ckpts[0].get('choices', [])
                return {"models": choices}
            return {"models": []}
        except Exception as e:
            return {"error": str(e)}
    
    def get_outputs(self, prefix: str = "oliver") -> list:
        """Get recent outputs"""
        if not OUTPUT_DIR.exists():
            return []
        
        files = sorted(
            OUTPUT_DIR.glob(f"{prefix}_*.png"),
            key=lambda x: x.stat().st_mtime,
            reverse=True
        )[:10]
        
        return [{"name": f.name, "time": f.stat().st_mtime} for f in files]
    
    def wait_for_completion(self, prompt_id: str, timeout: int = 120) -> bool:
        """Wait for a generation to complete"""
        start = time.time()
        while time.time() - start < timeout:
            r = requests.get(f"{COMFY_URL}/history", timeout=5)
            history = r.json()
            
            if prompt_id in history.get('history', {}):
                data = history['history'][prompt_id]
                if data.get('status', {}).get('completed', False):
                    return True
            
            time.sleep(2)
        return False


def main():
    import sys
    
    oliver = Oliver()
    
    if len(sys.argv) < 2:
        print("🎨 Oliver - Creative Director")
        print("=" * 40)
        print("Usage: oliver <command> [args...]")
        print("")
        print("Commands:")
        print("  check              - Check ComfyUI status")
        print("  generate <prompt>  - Generate image")
        print("  neg <prompt>      - Generate with negative prompt")
        print("  size WxH <prompt>  - Generate custom size")
        print("  history [n]       - View recent generations")
        print("  models            - List available models")
        print("  outputs           - List recent outputs")
        print("")
        print("Examples:")
        print("  oliver generate a portrait of a warrior")
        print("  oliver neg ugly,blurry a fantasy landscape")
        print("  oliver size 512x512 a minimalist logo")
        return
    
    cmd = sys.argv[1]
    
    if cmd == "check":
        if oliver.check():
            print("✅ ComfyUI: RUNNING on port 8000")
        else:
            print("❌ ComfyUI: NOT RUNNING")
            print("   Start: open /Applications/ComfyUI.app")
    
    elif cmd == "generate":
        if len(sys.argv) < 3:
            print("Usage: oliver generate <prompt>")
            return
        
        prompt = " ".join(sys.argv[2:])
        result = oliver.generate(prompt)
        
        if result.get('status') == 'queued':
            print(f"✅ {result['message']}")
            print(f"   Waiting for completion...")
            
            if oliver.wait_for_completion(result['prompt_id']):
                print(f"   ✅ Complete! Image saved.")
                outputs = oliver.get_outputs(f"oliver_{result['seed']}")
                if outputs:
                    print(f"   📄 {outputs[0]['name']}")
            else:
                print("   ⏳ Still running...")
        else:
            print(f"❌ {result.get('message', 'Unknown error')}")
    
    elif cmd == "neg":
        if len(sys.argv) < 3:
            print("Usage: oliver neg <negative> <positive>")
            return
        
        # Format: oliver neg "ugly" "beautiful sunset"
        negative = sys.argv[2]
        prompt = " ".join(sys.argv[3:]) if len(sys.argv) > 3 else "a beautiful scene"
        
        result = oliver.generate(prompt, negative=negative)
        
        if result.get('status') == 'queued':
            print(f"✅ Queued with negative prompt")
            print(f"   Prompt: {prompt}")
            print(f"   Negative: {negative}")
        else:
            print(f"❌ {result.get('message', 'Error')}")
    
    elif cmd == "size":
        if len(sys.argv) < 4:
            print("Usage: oliver size WxH <prompt>")
            return
        
        dims = sys.argv[2].split('x')
        if len(dims) != 2:
            print("Invalid size format. Use: WxH (e.g., 512x512)")
            return
        
        try:
            width, height = int(dims[0]), int(dims[1])
        except:
            print("Invalid dimensions")
            return
        
        prompt = " ".join(sys.argv[3:])
        result = oliver.generate(prompt, width=width, height=height)
        
        if result.get('status') == 'queued':
            print(f"✅ Queued {width}x{height} image")
        else:
            print(f"❌ {result.get('message', 'Error')}")
    
    elif cmd == "history":
        limit = int(sys.argv[2]) if len(sys.argv) > 2 else 10
        result = oliver.get_history(limit)
        
        if 'error' in result:
            print(f"❌ {result['error']}")
            return
        
        print(f"📜 Recent Generations:")
        for item in result.get('history', []):
            status = "✅" if item.get('completed') else "⏳"
            print(f"   {status} {item['prompt_id'][:12]}...")
    
    elif cmd == "models":
        result = oliver.list_models()
        
        if 'error' in result:
            print(f"❌ {result['error']}")
            return
        
        models = result.get('models', [])
        print(f"📦 Available Models ({len(models)}):")
        for m in models[:15]:
            print(f"   {m}")
    
    elif cmd == "outputs":
        files = oliver.get_outputs()
        print(f"🖼️ Recent Outputs:")
        for f in files:
            print(f"   {f['name']}")
    
    else:
        print(f"Unknown command: {cmd}")
        print("Run 'oliver' for help")


if __name__ == "__main__":
    main()
